[
  {
    "id": "atom_settings_wifi",
    "version": 1,
    "status": "active",
    "signature": {"domain": "device_settings", "action": "wifi", "required_tools": ["bash"], "required_slots": ["state"]},
    "triggers": [
      {"type": "regex", "value": "(?i)(?=.*\\b(turn|switch|enable|disable|toggle)\\b)(?=.*\\b(wifi|wi-fi|wireless|wlan)\\b)", "flags": "i",
       "components": {"intent_verbs": ["turn", "switch", "enable", "disable", "toggle"], "objects": ["wifi", "wireless"], "skill_terms": ["wifi", "wi-fi", "wireless", "wlan"]}}
    ],
    "slots": [{"name": "state", "type": "string", "required": true, "description": "on | off"}],
    "steps": [{"tool": "bash", "args_template": "settings wifi --state {{state}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Connectivity toggle family — all five share '--state on/off'; the subcommand (wifi/bluetooth/airplane/dnd/dark-mode) is the only discriminator. A dense sibling family for router stress."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Turn Wi-Fi on or off.", "example_queries": ["turn wifi off", "enable wireless", "switch wi-fi on"]}
  },
  {
    "id": "atom_settings_bluetooth",
