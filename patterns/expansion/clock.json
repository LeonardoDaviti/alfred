[
  {
    "id": "atom_clock_timer_start",
    "version": 1,
    "status": "active",
    "signature": {"domain": "clock", "action": "timer_start", "required_tools": ["bash"], "required_slots": ["duration"]},
    "triggers": [
      {"type": "regex", "value": "(?i)(?=.*\\b(set|start|create|put on|run)\\b)(?=.*\\b(timer|countdown)\\b)", "flags": "i",
       "components": {"intent_verbs": ["set", "start", "create", "put on", "run"], "objects": ["timer", "countdown"], "skill_terms": ["timer", "countdown", "minutes", "seconds"]}}
    ],
    "slots": [{"name": "duration", "type": "string", "required": true, "description": "Duration like '10m', '90s', '1h30m'"}],
    "steps": [{"tool": "bash", "args_template": "clock timer start --duration {{duration}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Unified clock skill — timer family. Real backend fires via systemd-run --user --on-active; mock here for binding-only. Sibling of alarm set (timer=relative duration vs alarm=absolute time)."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Start a countdown timer for a relative duration.", "example_queries": ["set a timer for 10 minutes", "start a 90 second countdown", "put on a timer for an hour and a half"]}
  },
