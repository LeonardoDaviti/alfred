[
  {
    "id": "atom_spotify_play",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "spotify",
      "action": "play_playback",
      "required_tools": ["bash"],
      "required_slots": []
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(play|resume|start|put on)\\b)(?=.*\\b(music|song|track|spotify|playback|tune|playlist|something)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["play", "resume", "start", "put on"],
          "objects": ["music", "song", "track", "playlist"],
          "skill_terms": ["music", "song", "track", "spotify", "playback", "tune", "playlist"]
        }
      }
    ],
    "slots": [
      {"name": "query", "type": "string", "required": false, "description": "Optional track/artist to play"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "spotify play{{?query: --track \"{{query}}\"}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Mock skill — binding-only. Sibling of pause/next/previous."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Start or resume Spotify playback, optionally a specific track.",
      "example_queries": ["play some music", "resume spotify", "put on the daft punk track", "start playback"]
    }
  },
