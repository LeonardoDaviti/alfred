  {
    "id": "atom_svc_enable",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "service",
      "action": "enable_unit",
      "required_tools": ["bash"],
      "required_slots": ["unit"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(enable|auto[- ]?start|start on boot|start at boot|persist)\\b)(?=.*\\b(service|unit|daemon|systemd|nginx|docker|postgres|boot)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["enable", "auto-start", "start on boot", "persist"],
          "objects": ["service", "unit", "daemon"],
          "skill_terms": ["service", "unit", "daemon", "systemd", "nginx", "docker", "postgres", "boot"]
        }
      }
    ],
    "slots": [
      {"name": "unit", "type": "string", "required": true, "description": "Systemd unit name"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "svc enable --unit \"{{unit}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Boot-persistence write — sibling of disable. Subcommand discriminates from start."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Enable a systemd service unit to start on boot.",
      "example_queries": ["enable the nginx service on boot", "make the docker daemon auto-start", "start postgres at boot"]
    }
  },
  {
