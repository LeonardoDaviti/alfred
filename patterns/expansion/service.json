[
  {
    "id": "atom_svc_start",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "service",
      "action": "start_unit",
      "required_tools": ["bash"],
      "required_slots": ["unit"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(start|launch|bring up|spin up|fire up)\\b)(?=.*\\b(service|unit|daemon|systemd|nginx|docker|postgres|service\\.service)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["start", "launch", "bring up", "spin up", "fire up"],
          "objects": ["service", "unit", "daemon"],
          "skill_terms": ["service", "unit", "daemon", "systemd", "nginx", "docker", "postgres"]
        }
      }
    ],
    "slots": [
      {"name": "unit", "type": "string", "required": true, "description": "Systemd unit name, e.g. nginx.service"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "svc start --unit \"{{unit}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Mock skill — binding-only (command correctness). Sibling of stop/restart/status/enable/disable — the subcommand word is the discriminator."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Start a systemd service unit.",
      "example_queries": ["start the nginx service", "launch the docker daemon", "bring up the postgres unit"]
    }
  },
  {
