    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Sibling of start — opposite action, same domain. Subcommand discriminates."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Stop a systemd service unit.",
      "example_queries": ["stop the nginx service", "shut down the docker daemon", "kill the postgres unit"]
    }
  },
