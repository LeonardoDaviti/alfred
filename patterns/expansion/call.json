[
  {
    "id": "atom_call_dial",
    "version": 1,
    "status": "active",
    "signature": {"domain": "call", "action": "dial", "required_tools": ["bash"], "required_slots": ["contact"]},
    "triggers": [
      {"type": "regex", "value": "(?i)\\b(call|phone|dial|ring)\\b", "flags": "i",
       "components": {"intent_verbs": ["call", "phone", "dial", "ring"], "objects": ["contact", "number"], "skill_terms": ["call", "phone", "dial", "ring"]}}
    ],
    "slots": [{"name": "contact", "type": "string", "required": true, "description": "Contact name or phone number"}],
    "steps": [{"tool": "bash", "args_template": "call dial --to \"{{contact}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Mock telephony. Pairs with contacts.search in composite_call_contact (name -> number -> dial)."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Place a phone call to a contact or number.", "example_queries": ["call mom", "phone John Smith", "dial +995555123456"]}
  },
  {
    "id": "atom_call_redial",
