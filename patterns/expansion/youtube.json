    "id": "composite_youtube_to_mp3",
    "version": 1,
    "status": "active",
    "type": "composite",
    "signature": {
      "domain": "youtube",
      "action": "youtube_to_normalized_mp3",
      "required_tools": ["bash"],
      "composite_slots": ["url"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)\\b(youtube to mp3|yt to mp3|rip .* and convert|download .* and make .* mp3|podcast clip from)\\b",
        "flags": "i",
        "components": {
          "intent_verbs": ["youtube to mp3", "rip and convert", "download and make mp3"]
        }
      }
    ],
    "atoms": [
      {"pattern_id": "atom_youtube_download_audio", "slot_bindings": {"url": "{{url}}"}},
      {"pattern_id": "atom_ffmpeg_transcode", "slot_bindings": {"input": "/tmp/_yt_audio.mp3", "output": "/tmp/_final.mp3"}}
    ],
    "output_template": "[YT->MP3] downloaded audio and normalised to mp3.",
    "parse_schema": {},
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Download YouTube audio and normalise it to MP3 (yt-dlp then ffmpeg).",
      "example_queries": ["youtube to mp3 <url>", "rip this video and convert it to a clean mp3", "make a podcast clip from <url>"],
