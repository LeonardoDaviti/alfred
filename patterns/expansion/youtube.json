[
  {
    "id": "atom_youtube_download_video",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "youtube",
      "action": "download_video",
      "required_tools": ["bash"],
      "required_slots": ["url"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(download|grab|save|fetch|get|rip)\\b)(?=.*\\b(video|youtube|yt|clip|watch)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["download", "grab", "save", "fetch", "get", "rip"],
          "objects": ["video", "clip"],
          "skill_terms": ["video", "youtube", "yt", "clip", "watch"]
        }
      }
    ],
    "slots": [
      {"name": "url", "type": "string", "required": true, "description": "YouTube URL"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "yt-dlp \"{{url}}\"", "retries": 0, "timeout": 120, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "exit_code == 0"}],
    "notes": ["Mock/binding-only (network) — bare yt-dlp downloads the video."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Download a YouTube video.",
      "example_queries": ["download this youtube video <url>", "grab the video at youtu.be/abc", "save that yt clip"]
    }
  },
  {
    "id": "atom_youtube_download_audio",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "youtube",
      "action": "download_audio_mp3",
      "required_tools": ["bash"],
      "required_slots": ["url"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(download|grab|save|extract|get|rip)\\b)(?=.*\\b(audio|mp3|song|music|sound)\\b)(?=.*\\b(youtube|yt|video|url|link)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["download audio", "extract mp3", "rip the song"],
          "objects": ["audio", "mp3", "song"],
          "skill_terms": ["audio", "mp3", "song", "music", "youtube", "yt"]
        }
      }
    ],
    "slots": [
      {"name": "url", "type": "string", "required": true, "description": "YouTube URL"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "yt-dlp -x --audio-format mp3 \"{{url}}\"", "retries": 0, "timeout": 120, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "exit_code == 0"}],
    "notes": ["Sibling of download_video — discriminator is -x --audio-format mp3."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Download a YouTube video as MP3 audio.",
      "example_queries": ["download the mp3 of this youtube video", "rip the audio from that yt link", "get just the song from <url>"]
    }
  },
  {
