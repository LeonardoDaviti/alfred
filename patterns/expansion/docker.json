[
  {
    "id": "atom_dock_start",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "docker",
      "action": "start_container",
      "required_tools": ["bash"],
      "required_slots": ["container"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(start|launch|run|bring up|spin up|fire up)\\b)(?=.*\\b(container|docker|image|box)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["start", "launch", "run", "bring up", "spin up", "fire up"],
          "objects": ["container", "image"],
          "skill_terms": ["container", "docker", "image", "box"]
        }
      }
    ],
    "slots": [
      {"name": "container", "type": "string", "required": true, "description": "Container name or id"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "dock start --container \"{{container}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Mock skill — binding-only (command correctness). Sibling of stop/restart/remove/logs/ps — the subcommand word is the discriminator."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Start a Docker container.",
      "example_queries": ["start the redis container", "launch the nginx docker container", "bring up the postgres box"]
    }
  },
