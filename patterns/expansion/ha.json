  {
    "id": "atom_ha_get_state",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "home_assistant",
      "action": "read_entity_state",
      "required_tools": ["bash"],
      "required_slots": ["entity"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(state|status|is|what'?s|reading|value|level)\\b)(?=.*\\b(sensor|thermostat|temperature|humidity|door|lock|battery|light|switch|garage)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["state", "status", "what's", "reading", "value", "level"],
          "objects": ["sensor", "thermostat", "door", "lock", "battery"],
          "skill_terms": ["sensor", "thermostat", "temperature", "humidity", "door", "lock", "battery", "light", "switch", "garage"]
        }
      }
    ],
    "slots": [
      {"name": "entity", "type": "string", "required": true, "description": "Entity id to query, e.g. sensor.living_room_temperature"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "ha state --entity \"{{entity}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Read action — sibling-distinct from the call/turn_* writes."],
