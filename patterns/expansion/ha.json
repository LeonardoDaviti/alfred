[
  {
    "id": "atom_ha_turn_on",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "home_assistant",
      "action": "turn_on_entity",
      "required_tools": ["bash"],
      "required_slots": ["entity"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(turn on|switch on|power on|enable|activate)\\b)(?=.*\\b(light|lights|lamp|switch|plug|fan|outlet|tv|heater|device|kitchen|bedroom|living room|garage)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["turn on", "switch on", "power on", "enable", "activate"],
          "objects": ["light", "lamp", "switch", "plug", "fan", "device"],
          "skill_terms": ["light", "lights", "lamp", "switch", "plug", "fan", "outlet", "tv", "heater", "kitchen", "bedroom", "living room", "garage"]
        }
      }
    ],
    "slots": [
      {"name": "entity", "type": "string", "required": true, "description": "Entity id or friendly name, e.g. light.kitchen"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "ha call --domain {{domain}} --service turn_on --entity \"{{entity}}\"", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Mock skill — binding-only (command correctness). Sibling of turn_off/toggle."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Turn on a Home Assistant device or light.",
      "example_queries": ["turn on the kitchen light", "switch on the living room lamp", "power on the bedroom fan"]
    }
  },
