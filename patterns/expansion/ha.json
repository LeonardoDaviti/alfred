      "source": "manual_expansion",
      "natural_language_intent": "Read the current state of a Home Assistant sensor or device.",
      "example_queries": ["what's the living room temperature sensor reading", "is the front door locked", "check the garage battery level"]
    }
  },
  {
    "id": "atom_ha_set_temperature",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "home_assistant",
      "action": "set_climate_temperature",
      "required_tools": ["bash"],
      "required_slots": ["entity", "temp"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(set|change|adjust|put)\\b)(?=.*\\b(thermostat|temperature|heat|heating|climate|ac|degrees)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["set", "change", "adjust", "put"],
          "objects": ["thermostat", "temperature", "climate"],
          "skill_terms": ["thermostat", "temperature", "heat", "heating", "climate", "ac", "degrees"]
        }
      }
    ],
    "slots": [
      {"name": "entity", "type": "string", "required": true, "description": "Climate entity, e.g. climate.living_room"},
      {"name": "temp", "type": "number", "required": true, "description": "Target temperature"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "ha call --domain climate --service set_temperature --entity \"{{entity}}\" --temp {{temp}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Parameterised write — distinct service from turn_on."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Set the thermostat target temperature in Home Assistant.",
      "example_queries": ["set the thermostat to 21 degrees", "change the living room temperature to 19", "put the heating at 23"]
    }
  },
  {
    "id": "atom_ha_set_brightness",
    "version": 1,
    "status": "active",
    "signature": {
      "domain": "home_assistant",
      "action": "set_light_brightness",
      "required_tools": ["bash"],
      "required_slots": ["entity", "level"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)(?=.*\\b(dim|brighten|set|adjust)\\b)(?=.*\\b(light|lights|lamp|brightness)\\b)",
        "flags": "i",
        "components": {
          "intent_verbs": ["dim", "brighten", "set brightness", "adjust"],
          "objects": ["light", "lamp", "brightness"],
          "skill_terms": ["light", "lights", "lamp", "brightness"]
        }
      }
    ],
    "slots": [
      {"name": "entity", "type": "string", "required": true, "description": "Light entity"},
      {"name": "level", "type": "number", "required": true, "description": "Brightness 0-255"}
    ],
    "steps": [
      {"tool": "bash", "args_template": "ha call --domain light --service turn_on --entity \"{{entity}}\" --brightness {{level}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}
    ],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Hard sibling: same turn_on service as atom_ha_turn_on but carries --brightness — the discriminator is the brightness slot, not the verb."],
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Dim or brighten a Home Assistant light to a brightness level.",
      "example_queries": ["dim the bedroom lights to 50", "brighten the kitchen light to 200", "set the lamp brightness to 120"]
    }
  },
