  {
    "id": "atom_media_volume_set",
    "version": 1,
    "status": "active",
    "signature": {"domain": "media", "action": "volume_set", "required_tools": ["bash"], "required_slots": ["level"]},
    "triggers": [
      {"type": "regex", "value": "(?i)(?=.*\\b(set|change|adjust)\\b)(?=.*\\b(player|media|playback)\\b)(?=.*\\b(volume)\\b)", "flags": "i",
       "components": {"intent_verbs": ["set", "change", "adjust"], "objects": ["volume", "player", "media"], "skill_terms": ["media", "player", "volume", "playback"]}}
    ],
    "slots": [{"name": "level", "type": "number", "required": true, "description": "Player volume 0-100"}],
    "steps": [{"tool": "bash", "args_template": "media volume --level {{level}}", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["TRIPLE collision: media volume vs sys volume set (system master) vs spotify volume — 'player/media' term discriminates from system master volume."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Set the media player volume to a level (player, not system master).", "example_queries": ["set the player volume to 50", "change the media volume to 30", "adjust playback volume to 70"]}
  }
