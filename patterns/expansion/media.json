[
  {
    "id": "atom_media_play",
    "version": 1,
    "status": "active",
    "signature": {"domain": "media", "action": "play", "required_tools": ["bash"], "required_slots": []},
    "triggers": [
      {"type": "regex", "value": "(?i)\\b(play|resume|unpause|continue)\\b.*\\b(media|music|playback|track|it|song)\\b|^\\s*(play|resume)\\s*$", "flags": "i",
       "components": {"intent_verbs": ["play", "resume", "unpause", "continue"], "objects": ["media", "playback", "music"], "skill_terms": ["media", "playback", "player", "resume"]}}
    ],
    "slots": [],
    "steps": [{"tool": "bash", "args_template": "media play", "retries": 0, "timeout": 10, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Generic OS media control (playerctl). CROSS-SKILL collision with spotify play — media play RESUMES current playback (no query), spotify play takes a --track query. The absence of a track is the discriminator."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Resume the current media playback (generic player, not Spotify-specific).", "example_queries": ["resume playback", "play the media", "unpause"]}
  },
  {
