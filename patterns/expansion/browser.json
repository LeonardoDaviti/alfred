[
  {
    "id": "atom_browser_open_url",
    "version": 1,
    "status": "active",
    "signature": {"domain": "browser", "action": "open_url", "required_tools": ["bash"], "required_slots": ["url"]},
    "triggers": [
      {"type": "regex", "value": "(?i)\\b(open|go to|navigate to|visit|load)\\b.*\\b(url|site|website|page|https?://|\\.com|\\.org)\\b", "flags": "i",
       "components": {"intent_verbs": ["open", "go to", "navigate to", "visit", "load"], "objects": ["url", "website", "page"], "skill_terms": ["url", "website", "site", "page", "browser"]}}
    ],
    "slots": [{"name": "url", "type": "string", "required": true, "description": "URL to open"}],
    "steps": [{"tool": "bash", "args_template": "browser open --url \"{{url}}\"", "retries": 0, "timeout": 30, "on_failure": "escalate_to_thinker"}],
    "validators": [{"assert": "stdout_parses_as_json"}, {"assert": "ok == true"}],
    "notes": ["Real backend: Playwright connect_over_cdp to the user's Chromium/Brave. Collision with app open (url vs app name)."],
    "metadata": {"source": "manual_expansion", "natural_language_intent": "Open a URL in the browser.", "example_queries": ["open github.com", "navigate to https://news.ycombinator.com", "visit the wikipedia page"]}
  },
  {
