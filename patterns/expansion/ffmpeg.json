      "required_tools": ["bash"],
      "composite_slots": ["input", "start", "end"]
    },
    "triggers": [
      {
        "type": "regex",
        "value": "(?i)\\b(make a gif|turn .* into a gif|gif from|create a gif|to gif)\\b",
        "flags": "i",
        "components": {
          "intent_verbs": ["make a gif", "turn into a gif", "gif from", "create a gif"]
        }
      }
