    "output_template": "[FFMPEG] trimmed {{input}} and converted to GIF.",
    "parse_schema": {},
    "metadata": {
      "source": "manual_expansion",
      "natural_language_intent": "Make a GIF from a video segment: trim then convert to gif.",
      "example_queries": ["make a gif from video.mp4 between 0:05 and 0:08", "turn the first 3 seconds into a gif", "create a gif from this clip"],
      "estimated_atoms_run": 2,
      "estimated_llm_calls": 0
    }
  }
